# Docker Compose 起動時は compose.yaml の environment.DATABASE_URL（db:5432）で上書きされる
# go run での直接実行時はこの値が使われる
DATABASE_URL=postgres://todo:todo@localhost:5432/todo?sslmode=disable
JWT_SECRET=change-me-in-production
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_CALLBACK_URL=http://localhost:8080/auth/callback
WEB_FRONTEND_URL=http://localhost:3000
COOKIE_SECURE=false
